---
import Base from '../layouts/Base.astro';
---
<Base page="home" title="Mr Gole — Phuntsok Namgyel Lama · Nepali food & travel creator" description="Mr Gole (Phuntsok Namgyel Lama) is a Kathmandu-based Nepali food & travel content creator — and the founder of The Second Plate restaurant in Budhanilkantha. Everyday hustle, every plate a story.">
<main id="main">

  <!-- ============ Hero (statement overlay) ============ -->
  <section class="hero hero--creator" aria-label="Mr Gole">
    <div class="hero__media hero__media--creator"></div>
    <div class="hero__scrim"></div>
    <div class="hero__body">
      <p class="hero__kicker reveal">
        <span class="hero__kicker-rule" aria-hidden="true"></span>
        <span class="hero__kicker-ne" lang="ne">नमस्ते</span>
        <span class="hero__kicker-en">Namaste</span>
      </p>
      <h1 class="hero__statement reveal" data-delay="1">I'm <span>Mr Gole</span> — Phuntsok Namgyel Lama. I travel Nepal hunting the <span>best food</span>, and I built a <span>restaurant</span> so you can taste it too.</h1>
    </div>
  </section>

  <!-- ============ About ============ -->
  <section class="section" id="about">
    <div class="container">
      <div class="feature feature--first">
        <div class="split reveal">
          <div class="split__text">
            <p class="eyebrow">About</p>
            <h2 class="h2">A young dreamer with a camera and an appetite</h2>
            <p class="body">In my own words: a young and enthusiastic boy with a vision to make a change. I started filming the food I love across Kathmandu and beyond — honest, hungry, and a little bit obsessed. Today that journey lives on YouTube, where around 130K of you follow along, and at The Second Plate, the restaurant I opened in Budhanilkantha.</p>
            <div class="stats" role="list">
              <!-- NOTE[owner]: counts observed Jun 2026; re-verify before relying on exact numbers -->
              <div role="listitem"><div class="stat__num">~130K</div><div class="stat__label">YouTube subscribers</div></div>
              <div role="listitem"><div class="stat__num">~330</div><div class="stat__label">Videos</div></div>
              <div role="listitem"><div class="stat__num">~18.6M</div><div class="stat__label">Total views</div></div>
            </div>
            <div class="split__actions" style="margin-top:28px">
              <a class="mg-btn mg-btn--primary" href="/about">Who I am</a>
              <a class="mg-btn mg-btn--ghost" href="/about#journey">My journey <svg width="16" height="16" aria-hidden="true"><use href="#i-chevron"></use></svg></a>
            </div>
          </div>
          <div class="split__media">
            <div class="photo photo--img photo--zoom" style="background-image:url(/assets/img/gole-portrait.jpg);background-position:center 28%" role="img" aria-label="Mr Gole — Phuntsok Namgyel Lama"></div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ============ Notable videos ============ -->
  <section class="section section--cream" id="videos">
    <div class="container">
      <div class="section__head section__head--center reveal">
        <p class="eyebrow">Watch</p>
        <h2 class="h2">Some videos people loved</h2>
        <p class="body" style="margin-top:14px">Real favorites from the channel — scroll and take your pick.</p>
      </div>

      <div class="vgallery" role="list">
        <a class="vcard" style="--i:0" role="listitem" href="https://www.youtube.com/watch?v=-MjWfwRjXzU" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/-MjWfwRjXzU/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span><span class="vcard__views">258K views</span></span>
            <span class="vcard__body"><span class="vcard__title">Rs. 1.5 lakh for eating rice?</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:1" role="listitem" href="https://www.youtube.com/watch?v=kd9bzr4jbhc" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/kd9bzr4jbhc/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span><span class="vcard__views">204K views</span></span>
            <span class="vcard__body"><span class="vcard__title">Rs. 10,000 biryani challenge</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:2" role="listitem" href="https://www.youtube.com/watch?v=AYNEyEq5UQM" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/AYNEyEq5UQM/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span><span class="vcard__views">119K views</span></span>
            <span class="vcard__body"><span class="vcard__title">Exposing KFC Nepal</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:3" role="listitem" href="https://www.youtube.com/watch?v=9Jo5OTJrE6M" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/9Jo5OTJrE6M/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span><span class="vcard__views">80K views</span></span>
            <span class="vcard__body"><span class="vcard__title">Opening our own restaurant</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:4" role="listitem" href="https://www.youtube.com/watch?v=STYax0MZaCg" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/STYax0MZaCg/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span><span class="vcard__views">70K views</span></span>
            <span class="vcard__body"><span class="vcard__title">Best keema noodles in Nepal</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:5" role="listitem" href="https://www.youtube.com/watch?v=TgjMPmF4DiY" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/TgjMPmF4DiY/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span><span class="vcard__views">59K views</span></span>
            <span class="vcard__body"><span class="vcard__title">Best rice bowl in Kathmandu</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:6" role="listitem" href="https://www.youtube.com/watch?v=JZj5PwW9kks" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/JZj5PwW9kks/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span></span>
            <span class="vcard__body"><span class="vcard__title">Spend Rs.10,000 in 24 hours</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:7" role="listitem" href="https://www.youtube.com/watch?v=WKu2ZxZEH_I" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/WKu2ZxZEH_I/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span></span>
            <span class="vcard__body"><span class="vcard__title">Worst copy of famous fast food</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:8" role="listitem" href="https://www.youtube.com/watch?v=yUe3ApluD7A" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/yUe3ApluD7A/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span></span>
            <span class="vcard__body"><span class="vcard__title">5 best chicken dishes in Kathmandu</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:9" role="listitem" href="https://www.youtube.com/watch?v=IyTGvxnoYBM" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/IyTGvxnoYBM/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span></span>
            <span class="vcard__body"><span class="vcard__title">Budhanilkantha food hunt</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:10" role="listitem" href="https://www.youtube.com/watch?v=dCeVv1eUZN0" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/dCeVv1eUZN0/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span></span>
            <span class="vcard__body"><span class="vcard__title">24 lucky subscribers at The Second Plate</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
        <a class="vcard" style="--i:11" role="listitem" href="https://www.youtube.com/watch?v=X03cFbBNbi8" target="_blank" rel="noopener">
          <span class="vcard__inner">
            <span class="vcard__thumb" style="background-image:url(https://i.ytimg.com/vi/X03cFbBNbi8/hqdefault.jpg)"><span class="vcard__play"><svg aria-hidden="true"><use href="#i-play"></use></svg></span></span>
            <span class="vcard__body"><span class="vcard__title">Best sukuti in Kathmandu Valley</span><span class="vcard__cta">Watch on YouTube<svg aria-hidden="true"><use href="#i-chevron"></use></svg></span></span>
          </span>
        </a>
      </div>

      <div style="text-align:center;margin-top:48px" class="reveal">
        <a class="mg-btn mg-btn--secondary mg-btn--lg" href="https://www.youtube.com/@mrgole8" target="_blank" rel="noopener">See all videos on YouTube</a>
      </div>
    </div>
  </section>

  <!-- ============ Featured: The Second Plate cross-promo ============ -->
  <section class="section section--tight">
    <div class="container">
      <div class="feature feature--first">
        <div class="split split--reverse reveal">
          <div class="split__text">
            <p class="eyebrow">My restaurant</p>
            <h2 class="h2">The Second Plate</h2>
            <p class="body">In 2026 I teamed up with friends to open The Second Plate in Budhanilkantha — a warm, hearty spot built on one simple idea: because one plate is never enough. Come for the buff Mo:Mo, stay for the keema noodles.</p>
            <div class="split__actions">
              <a class="mg-btn mg-btn--primary" href="/the-second-plate">Visit The Second Plate</a>
              <a class="mg-btn mg-btn--ghost" href="/the-second-plate#menu">See the menu <svg width="16" height="16" aria-hidden="true"><use href="#i-chevron"></use></svg></a>
            </div>
          </div>
          <div class="split__media">
            <div class="photo photo--img photo--zoom" style="background-image:url(/assets/img/billboard.png);background-color:#f4f2ee" role="img" aria-label="The Second Plate — some meals bring you back"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Social ============ -->
  <section class="section section--cream">
    <div class="container">
      <div class="section__head section__head--center reveal">
        <p class="eyebrow">Follow along</p>
        <h2 class="h2">Join the journey</h2>
      </div>
      <!-- NOTE[owner]: follower numbers omitted on purpose — they drift. Re-add only after re-verifying. -->
      <div class="socials">
        <a class="social-card reveal" href="https://www.youtube.com/@mrgole8" target="_blank" rel="noopener">
          <span class="social-card__icon"><svg aria-hidden="true"><use href="#i-youtube"></use></svg></span>
          <span><span class="social-card__handle">@mrgole8</span><span class="social-card__platform">YouTube</span></span>
        </a>
        <a class="social-card reveal" data-delay="1" href="https://www.tiktok.com/@mrgole_official" target="_blank" rel="noopener">
          <span class="social-card__icon"><svg aria-hidden="true"><use href="#i-tiktok"></use></svg></span>
          <span><span class="social-card__handle">@mrgole_official</span><span class="social-card__platform">TikTok</span></span>
        </a>
        <a class="social-card reveal" data-delay="2" href="https://www.instagram.com/mr.gole_nepal/" target="_blank" rel="noopener">
          <span class="social-card__icon"><svg aria-hidden="true"><use href="#i-instagram"></use></svg></span>
          <span><span class="social-card__handle">@mr.gole_nepal</span><span class="social-card__platform">Instagram</span></span>
        </a>
        <a class="social-card reveal" data-delay="3" href="https://www.facebook.com/mrgole8" target="_blank" rel="noopener">
          <span class="social-card__icon"><svg aria-hidden="true"><use href="#i-facebook"></use></svg></span>
          <span><span class="social-card__handle">/mrgole8</span><span class="social-card__platform">Facebook</span></span>
        </a>
      </div>
    </div>
  </section>

</main>
</Base>
