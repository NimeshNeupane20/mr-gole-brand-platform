---
import Base from '../layouts/Base.astro';
---
<Base page="about" title="About Mr Gole — Phuntsok Namgyel Lama" description="About Mr Gole (Phuntsok Namgyel Lama) — a Kathmandu-based Nepali food & travel content creator with ~130K YouTube subscribers, and founder of The Second Plate restaurant in Budhanilkantha.">
<main id="main">

  <!-- ============ About hero ============ -->
  <section class="section section--cream" style="padding-top:120px">
    <div class="container">
      <div class="section__head reveal">
        <p class="eyebrow">About</p>
        <h1 class="h1" style="font-size:var(--text-hero)">Meet Mr Gole</h1>
        <p class="lead" style="margin-top:18px;max-width:700px">Phuntsok Namgyel Lama — a Kathmandu-based food &amp; travel content creator, and a co-founder of The Second Plate. Everyday hustle, every plate a story.</p>
      </div>
    </div>
  </section>

  <!-- ============ Bio ============ -->
  <section class="section" id="bio">
    <div class="container">
      <div class="feature feature--first">
        <div class="split reveal">
          <div class="split__text">
            <p class="eyebrow">Who I am</p>
            <h2 class="h2">A young dreamer with a camera and an appetite</h2>
            <p class="body">In my own words: a young and enthusiastic boy with a vision to make a change. I started filming the food I love across Kathmandu and beyond — honest, hungry, and a little bit obsessed. What began as simple food hunts grew into a community of around 130,000 people on YouTube, with more than 18 million views. In 2026, that journey became something you can taste: The Second Plate, my restaurant in Budhanilkantha.</p>
            <div class="stats" role="list">
              <!-- NOTE[owner]: counts observed Jun 2026; re-verify before relying on exact numbers -->
              <div role="listitem"><div class="stat__num">~130K</div><div class="stat__label">YouTube subscribers</div></div>
              <div role="listitem"><div class="stat__num">~330</div><div class="stat__label">Videos</div></div>
              <div role="listitem"><div class="stat__num">~18.6M</div><div class="stat__label">Total views</div></div>
            </div>
          </div>
          <div class="split__media">
            <div class="photo photo--img photo--zoom" style="background-image:url(/assets/img/gole-portrait.jpg);background-position:center 22%" role="img" aria-label="Mr Gole — Phuntsok Namgyel Lama"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ What I do (content lanes) ============ -->
  <section class="section section--cream" id="what">
    <div class="container">
      <div class="section__head section__head--center reveal">
        <p class="eyebrow">What I do</p>
        <h2 class="h2">Three kinds of food adventures</h2>
        <p class="body" style="margin-top:14px">From cheap local gems to all-out eating challenges — plus the occasional honest taste-test.</p>
      </div>
      <div class="lanes">
        <article class="lane reveal" data-delay="1">
          <div class="lane__no">01</div>
          <h3 class="h3">Budget food hunts</h3>
          <p class="body">Chasing the best momo, sekuwa and khaja across Kathmandu, Dharan, Itahari, Jhapa and beyond — proving great food doesn't need a big budget.</p>
        </article>
        <article class="lane reveal" data-delay="2">
          <div class="lane__no">02</div>
          <h3 class="h3">Big-money eating challenges</h3>
          <p class="body">Nepal's first-ever bhat eating competition, 2KG biryani runs, and "spend it all in 24 hours" dares — my most-loved, most-watched format.</p>
        </article>
        <article class="lane reveal" data-delay="3">
          <div class="lane__no">03</div>
          <h3 class="h3">Honest taste-tests</h3>
          <p class="body">Cheap vs expensive, original vs copy, brand call-outs — tasting it side by side and telling you the truth. Plus travel editions across Nepal and India.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- ============ Journey — alternating timeline (relocated from home) ============ -->
  <section class="section" id="journey">
    <div class="container">
      <div class="section__head section__head--center reveal">
        <p class="eyebrow">Journey</p>
        <h2 class="h2">The journey so far</h2>
        <p class="body" style="margin-top:14px">From a camera and an appetite to a community — and a restaurant of my own.</p>
      </div>

      <div class="timeline">
        <span class="timeline__line reveal" aria-hidden="true"></span>

        <div class="beat beat--left reveal">
          <div class="beat__node" aria-hidden="true">01</div>
          <div class="beat__content">
            <div class="beat__num"><span data-count="130" data-suffix="K+">130K+</span></div>
            <div class="beat__sub">+18.6M views</div>
            <h3 class="beat__title">A community of food lovers</h3>
            <p class="beat__text">Built a YouTube following around honest, hungry Nepali food — and it keeps growing.</p>
          </div>
          <div class="beat__media">
            <div class="photo photo--img" style="background-image:url(/assets/img/gole-portrait.jpg);background-position:center 22%" role="img" aria-label="Mr Gole"></div>
          </div>
        </div>

        <div class="beat beat--right reveal">
          <div class="beat__node" aria-hidden="true">02</div>
          <div class="beat__content">
            <div class="beat__num">1<span class="beat__num-sm">st</span></div>
            <h3 class="beat__title">Nepal's first bhat competition</h3>
            <p class="beat__text">Created and hosted Nepal's first-ever bhat (rice) eating competition — one of the most-watched things I've ever done.</p>
          </div>
          <div class="beat__media">
            <div class="photo photo--img" style="background-image:url(https://i.ytimg.com/vi/-MjWfwRjXzU/hqdefault.jpg)" role="img" aria-label="Bhat eating competition"></div>
          </div>
        </div>

        <div class="beat beat--left reveal">
          <div class="beat__node" aria-hidden="true">03</div>
          <div class="beat__content">
            <div class="beat__num beat__num--word">Press</div>
            <h3 class="beat__title">Recognized &amp; featured</h3>
            <p class="beat__text">Profiled by Routine of Nepal Banda and embraced by Nepal's food-creator community — Lex Limbu, foodelicious and more.</p>
          </div>
          <div class="beat__media">
            <div class="photo photo--img" style="background-image:url(https://i.ytimg.com/vi/kd9bzr4jbhc/hqdefault.jpg)" role="img" aria-label="Featured — viral eating challenge"></div>
          </div>
        </div>

        <div class="beat beat--right reveal">
          <div class="beat__node" aria-hidden="true">04</div>
          <div class="beat__content">
            <div class="beat__num"><span data-count="2026" data-plain="1">2026</span></div>
            <h3 class="beat__title">From screen to street</h3>
            <p class="beat__text">Turned the journey into something real: The Second Plate, my restaurant in Budhanilkantha, Kathmandu.</p>
          </div>
          <div class="beat__media">
            <div class="photo photo--img" style="background-image:url(/assets/img/hero-restaurant.png)" role="img" aria-label="The Second Plate"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Recognition ============ -->
  <section class="section section--blush" id="recognition">
    <div class="container">
      <div class="section__head section__head--center reveal">
        <p class="eyebrow">Recognition</p>
        <h2 class="h2">Kind words &amp; features</h2>
      </div>
      <figure class="reveal" style="max-width:820px;margin:0 auto;text-align:center">
        <span style="display:inline-flex;color:var(--brand-red);margin-bottom:14px"><svg width="40" height="40" aria-hidden="true"><use href="#i-quote"></use></svg></span>
        <blockquote style="border:0;margin:0;padding:0">
          <p class="h3" style="font-weight:600;line-height:1.3">"24-year-old Phuntsok Namgyel Lama, aka Mr Gole, is a popular food and travel content creator."</p>
        </blockquote>
        <figcaption class="body" style="margin-top:18px;font-weight:600;color:var(--fg1)">Routine of Nepal Banda</figcaption>
        <p class="body" style="margin-top:8px">A Kathmandu-based creator known for relatable, honest narration.</p>
      </figure>
      <p class="body reveal" style="max-width:640px;margin:32px auto 0;text-align:center">
        The wider food-creator community has been generous too — from Lex Limbu to foodelicious and many more — sharing the journey and cheering on The Second Plate.
      </p>
    </div>
  </section>

  <!-- ============ The Second Plate tie ============ -->
  <section class="section">
    <div class="container">
      <div class="feature feature--first">
        <div class="split split--reverse reveal">
          <div class="split__text">
            <p class="eyebrow">My restaurant</p>
            <h2 class="h2">The Second Plate</h2>
            <p class="body">In 2026 I teamed up with friends to open The Second Plate in Budhanilkantha — a warm, hearty spot built on one simple idea: because one plate is never enough. Come for the buff Mo:Mo, stay for the keema noodles.</p>
            <div class="split__actions">
              <a class="mg-btn mg-btn--primary" href="/the-second-plate">Visit The Second Plate</a>
              <a class="mg-btn mg-btn--ghost" href="/the-second-plate#menu">See the menu <svg width="16" height="16" aria-hidden="true"><use href="#i-chevron"></use></svg></a>
            </div>
          </div>
          <div class="split__media">
            <div class="photo photo--img photo--zoom" style="background-image:url(/assets/img/hero-restaurant.png)" role="img" aria-label="The Second Plate restaurant"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ Social ============ -->
  <section class="section section--cream">
    <div class="container">
      <div class="section__head section__head--center reveal">
        <p class="eyebrow">Follow along</p>
        <h2 class="h2">Join the journey</h2>
      </div>
      <!-- NOTE[owner]: follower numbers omitted on purpose — they drift. Re-add only after re-verifying. -->
      <div class="socials">
        <a class="social-card reveal" href="https://www.youtube.com/@mrgole8" target="_blank" rel="noopener">
          <span class="social-card__icon"><svg aria-hidden="true"><use href="#i-youtube"></use></svg></span>
          <span><span class="social-card__handle">@mrgole8</span><span class="social-card__platform">YouTube</span></span>
        </a>
        <a class="social-card reveal" data-delay="1" href="https://www.tiktok.com/@mrgole_official" target="_blank" rel="noopener">
          <span class="social-card__icon"><svg aria-hidden="true"><use href="#i-tiktok"></use></svg></span>
          <span><span class="social-card__handle">@mrgole_official</span><span class="social-card__platform">TikTok</span></span>
        </a>
        <a class="social-card reveal" data-delay="2" href="https://www.instagram.com/mr.gole_nepal/" target="_blank" rel="noopener">
          <span class="social-card__icon"><svg aria-hidden="true"><use href="#i-instagram"></use></svg></span>
          <span><span class="social-card__handle">@mr.gole_nepal</span><span class="social-card__platform">Instagram</span></span>
        </a>
        <a class="social-card reveal" data-delay="3" href="https://www.facebook.com/mrgole8" target="_blank" rel="noopener">
          <span class="social-card__icon"><svg aria-hidden="true"><use href="#i-facebook"></use></svg></span>
          <span><span class="social-card__handle">/mrgole8</span><span class="social-card__platform">Facebook</span></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="cta-band">
    <div class="container">
      <div class="reveal">
        <h2 class="h2">Come say hello</h2>
        <p class="body">Watch the journey on YouTube, or come taste it at The Second Plate in Budhanilkantha.</p>
        <div class="cta-actions">
          <a class="mg-btn mg-btn--primary mg-btn--lg" href="https://www.youtube.com/@mrgole8" target="_blank" rel="noopener">Watch on YouTube</a>
          <a class="mg-btn mg-btn--white mg-btn--lg" href="/the-second-plate">Visit the restaurant</a>
        </div>
      </div>
    </div>
  </section>

</main>
</Base>
