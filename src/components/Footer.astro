<script>
  // Fidget-spinner hover: ease-in to steady spin, ease-out to a gentle stop (no snap-back).
  // Uses the Web Animations API so the logo decelerates from its current angle.
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll('.yantra-credit').forEach((credit) => {
    const logo = credit.querySelector('.yantra-credit__logo');
    if (!logo || reduceMotion) return;

    const spin = logo.animate(
      [{ transform: 'rotate(0deg)' }, { transform: 'rotate(360deg)' }],
      { duration: 1100, iterations: Infinity, easing: 'linear' }
    );
    spin.pause();
    spin.playbackRate = 0;

    let raf = 0;
    const ramp = (target) => {
      cancelAnimationFrame(raf);
      if (target > 0) spin.play();
      const step = () => {
        const rate = spin.playbackRate;
        const next = rate + (target - rate) * 0.12; // exponential ease toward target
        if (Math.abs(target - next) < 0.01) {
          spin.playbackRate = target;
          if (target === 0) spin.pause();
          return;
        }
        spin.playbackRate = next;
        raf = requestAnimationFrame(step);
      };
      step();
    };

    credit.addEventListener('mouseenter', () => ramp(1));
    credit.addEventListener('mouseleave', () => ramp(0));
    credit.addEventListener('focusin', () => ramp(1));
    credit.addEventListener('focusout', () => ramp(0));
  });
</script>
