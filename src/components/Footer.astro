---
import YantraCredit from "./YantraCredit.astro";
---
<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="logo" href="/">Mr Gole</a>
        <p class="body">Exploring and celebrating Nepali food and culture — one plate at a time. Founder of The Second Plate, Budhanilkantha.</p>
      </div>
      <div>
        <div class="footer-col__head">Explore</div>
        <div class="footer-col__links">
          <a href="/about">About</a>
          <a href="#videos">Videos</a>
          <a href="/the-second-plate">The Second Plate</a>
        </div>
      </div>
      <div>
        <div class="footer-col__head">The Second Plate</div>
        <div class="footer-col__links">
          <a href="/the-second-plate">Restaurant</a>
          <a href="/the-second-plate#menu">Menu</a>
          <a href="/the-second-plate#visit">Location &amp; contact</a>
        </div>
      </div>
      <div>
        <div class="footer-col__head">Follow</div>
        <div class="footer-social">
          <a href="https://www.youtube.com/@mrgole8" target="_blank" rel="noopener"><svg aria-hidden="true"><use href="#i-youtube"></use></svg> YouTube</a>
          <a href="https://www.tiktok.com/@mrgole_official" target="_blank" rel="noopener"><svg aria-hidden="true"><use href="#i-tiktok"></use></svg> TikTok</a>
          <a href="https://www.instagram.com/mr.gole_nepal/" target="_blank" rel="noopener"><svg aria-hidden="true"><use href="#i-instagram"></use></svg> Instagram</a>
          <a href="https://www.facebook.com/mrgole8" target="_blank" rel="noopener"><svg aria-hidden="true"><use href="#i-facebook"></use></svg> Facebook</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="footer-bottom__row">
        <span>© <span data-year>2026</span> Mr Gole · Phuntsok Namgyel Lama</span>
        <span>Kathmandu, Nepal</span>
      </div>
      <YantraCredit />
    </div>
  </div>
</footer>
